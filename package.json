{
  "name": "productcanvas-ai",
  "version": "1.0.0",
  "description": "Universal AI image studio from layout templates and reference photos via Codex Local Bridge",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "postinstall": "node scripts/generate-placeholders.js",
    "icons": "node scripts/generate-icons.js",
    "start": "electron .",
    "test": "node test/basic.test.js && node test/locale.test.js && node test/brand-free.test.js && node test/dropped-files.test.js && node test/image-settings.test.js && node test/prompt-fidelity.test.js && node test/image-preflight.test.js && node test/layout-fidelity.test.js && node test/template-edit-pipeline.test.js",
    "dist:win": "npm run icons && node scripts/build-win.js"
  },
  "author": "Andre Lorbach",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/alorbach/productcanvas-ai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alorbach/productcanvas-ai.git"
  },
  "bugs": {
    "url": "https://github.com/alorbach/productcanvas-ai/issues"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "electron": "^42.4.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "ai.productcanvas",
    "productName": "ProductCanvas AI",
    "artifactName": "ProductCanvas-AI-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "docs/**/*",
      "LICENSE",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
